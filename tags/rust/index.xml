&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="ln">19&lt;/span>&lt;span class="cl"> &lt;span class="p">[&lt;/span>&lt;span class="mi">35&lt;/span>&lt;span class="p">]&lt;/span> &lt;span class="n">SSL&lt;/span> &lt;span class="n">connect&lt;/span> &lt;span class="n">error&lt;/span> &lt;span class="p">(&lt;/span>&lt;span class="n">schannel&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="n">next&lt;/span> &lt;span class="n">InitializeSecurityContext&lt;/span> &lt;span class="n">failed&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="n">CRYPT_E_NO_REVOCATION_CHECK&lt;/span> &lt;span class="p">(&lt;/span>&lt;span class="mh">0x80092012&lt;/span>&lt;span class="p">))&lt;/span>
